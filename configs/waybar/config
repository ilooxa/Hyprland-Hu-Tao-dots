{
	"layer": "top",
	"position": "top",
	"height": 30,
	"width": 1920,
	"margin-top": 0,

	
    "modules-left": ["custom/menu", "hyprland/workspaces","hyprland/window"],
    "modules-center": ["cpu", "memory","custom/music"],
    "modules-right": ["tray","pulseaudio","hyprland/language","clock","custom/power"],


    "cpu": {
		"format": "  {usage}%",
		"tooltip": false
    },


	"memory": {
		"format": "mem: {}%",
		"tooltip": false
	},


	"hyprland/window": {
		"format": "{class}",
		"separate-outputs": false,
},


	"custom/menu": {
		"format": "{icon}",
		"format-icons": "",
		"on-click": "wofi --show drun -c ~/.config/wofi/config -s ~/.config/wofi/style.css",
		"escape": true,
		"tooltip": false
	},


	"hyprland/workspaces": {
		"format": "{icon}",
		"on-click": "activate",
		"format-icons": {
			"urgent": "",
			"active": "",
			"default": ""

			},
		"tooltip": false
	},


	"hyprland/language": {
	    "format": "{}",
	    "format-en": "EN",
	    "format-ru": "RU",
	},


	"tray": {
		"icon-size": 16,
		"spacing": 16
	},


	"clock": {
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "{:%Y-%m-%d}"
	},



    "pulseaudio": {
		"scroll-step": 5,
		"format": "{icon}  {volume}%",
		"format-icons": {
			"default": ["", "", ""]
		},
		"on-click": "pavucontrol"
	},





	"custom/music": {
	"format": " {}",
	"interval": 1,
	"exec": "echo music",
	"on-click": "playerctl play-pause",
	"on-scroll-up": "playerctl next",
	"on-scroll-down": "playerctl previous",
	"escape": true,
	"tooltip": false
	},

        
	"custom/power": {
		"format" : "⏻",
		"tooltip": false,
		"on-click": "wlogout"
		}
	},
        

       
    "custom/wttr": {
        "format": "{}",
        "interval": 300,
        "exec": "curl -s wttr.in/Kholmskaya?format=1",
        },
